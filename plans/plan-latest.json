      "servings": "大人2＋子ども1（1日分）",
      "ingredients": [
        ["鶏むね肉", "300g"], ["玉ねぎ", "3/4個（約150g）"], ["にんじん", "1/3本（約60g）"], ["ピーマン", "1.5個（約60g）"],
